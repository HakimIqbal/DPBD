# ===== Application =====
NODE_ENV=development
PORT=3001

# ===== Database (Postgres / Supabase) =====
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-me
DATABASE_NAME=postgres

# ===== JWT =====
# Generate a long random string for production (at least 32 chars).
# `openssl rand -base64 48` works.
JWT_SECRET=dev-secret-replace-in-production-32-chars-or-more
JWT_REFRESH_SECRET=dev-refresh-secret-replace-in-production-32-chars

# ===== Frontend URL (used in email links + CORS) =====
FRONTEND_URL=http://localhost:3000

# ===== Midtrans (sandbox / dummy) =====
MIDTRANS_SERVER_KEY=SB-Mid-server-dummy
MIDTRANS_CLIENT_KEY=SB-Mid-client-dummy
MIDTRANS_ENVIRONMENT=sandbox

# ===== Email (leave blank to disable email service) =====
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@dpbd.org

# ===== CEO bootstrap =====
# These values seed the very first CEO account on initial server start
# (see backend/src/seeds/bootstrap.seed.ts). The bootstrap is idempotent:
# once a user with role='ceo' exists, these are ignored. In production
# you MUST set a strong CEO_BOOTSTRAP_PASSWORD before first start, then
# rotate it again immediately after first login via PATCH /users/profile.
CEO_BOOTSTRAP_EMAIL=ceo@dpbd.org
CEO_BOOTSTRAP_PASSWORD=
CEO_BOOTSTRAP_NAME=CEO DPBD

# ===== Test user seed (dev only) =====
# Used by `npx ts-node src/scripts/seed-test-users.ts` to create the
# CFO / IM / Risk / Dewan Pembina / Dewan Pengawas test accounts. All
# five share this password. The script refuses to run if this is unset
# or shorter than 8 chars — passwords don't go in source.
#
# Coordinate the actual value with your team (Slack DM, password
# manager, etc.). Never commit it.
TEST_USERS_PASSWORD=
